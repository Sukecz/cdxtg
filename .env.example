# === Required: Telegram ===
# Create a bot with @BotFather. Keep the real token only in telegram.env.
TELEGRAM_BOT_TOKEN=123456:replace_me

# Start with this empty, run the bot, send /id, then add the returned user ID.
# Separate multiple trusted users with commas.
TELEGRAM_ALLOWED_USER_IDS=

# === Optional: Codex defaults ===
# Empty uses this project plus workspaces discovered from local Codex history.
# To add paths explicitly, separate existing absolute paths with commas.
CODEX_WORKSPACES=

# Optional. Empty means the current Codex default.
CODEX_MODEL=

# Optional: minimal, low, medium, high, or xhigh.
CODEX_REASONING_EFFORT=

# Safe default. Supported values: read-only, workspace-write, danger-full-access.
CODEX_DEFAULT_MODE=read-only

# Local opt-in required before /mode write is accepted.
CODEX_ENABLE_WRITE=false

# Dangerous local opt-in. Enables /mode full after an in-Telegram confirmation.
CODEX_ENABLE_FULL_ACCESS=false

# Headless Telegram cannot answer interactive approvals.
CODEX_APPROVAL_POLICY=never

# Streaming UX: off, brief (default), or verbose.
TELEGRAM_STREAM_MODE=brief

# Log detail: debug, info, warn, or error.
LOG_LEVEL=info

# === Optional: rate-limit reset notifications ===
# 0 disables all background polling. A practical value is 900 (15 minutes).
# Minimum enabled value: 30 seconds.
CODEX_RATE_LIMIT_POLL_SECONDS=0

# A usage decrease of at least this many percentage points is also treated as a reset.
CODEX_RATE_LIMIT_RESET_DROP_PERCENT=5

# Empty chat IDs send alerts to the trusted users above. Group chat IDs may be negative.
TELEGRAM_RATE_LIMIT_NOTIFICATIONS=true
TELEGRAM_RATE_LIMIT_CHAT_IDS=

# === Optional: MQTT ===
# MQTT also requires CODEX_RATE_LIMIT_POLL_SECONDS to be greater than 0.
# Leave MQTT_URL empty to disable publishing. Keep credentials out of MQTT_URL.
MQTT_URL=
MQTT_TOPIC=cdxtg/codex/rate-limits
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=0
MQTT_RETAIN=true

# === Optional: Home Assistant MQTT Discovery ===
# Requires MQTT above. Creates a Codex Usage device without Home Assistant YAML.
MQTT_HOME_ASSISTANT_DISCOVERY=false
MQTT_HOME_ASSISTANT_DISCOVERY_PREFIX=homeassistant
MQTT_HOME_ASSISTANT_DEVICE_ID=cdxtg_codex
MQTT_HOME_ASSISTANT_DEVICE_NAME=Codex Usage
