# Telegram bot token from @BotFather. Never commit a real value.
TELEGRAM_BOT_TOKEN=123456:replace_me

# Comma-separated numeric Telegram user IDs. Leave empty only to discover your ID with /id.
TELEGRAM_ALLOWED_USER_IDS=

# Optional comma-separated workspaces added alongside paths discovered from Codex history.
CODEX_WORKSPACES=/home/me/projects/example

# Optional. Empty means the current Codex default.
CODEX_MODEL=

# Safe default. Supported values: read-only, workspace-write, danger-full-access.
CODEX_DEFAULT_MODE=read-only

# Local opt-in required before /mode write is accepted.
CODEX_ENABLE_WRITE=false

# Dangerous local opt-in. Enables /mode full after an in-Telegram confirmation.
CODEX_ENABLE_FULL_ACCESS=false

# Headless Telegram cannot answer interactive approvals.
CODEX_APPROVAL_POLICY=never

LOG_LEVEL=info
