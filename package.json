{
  "name": "cdxtg",
  "version": "1.1.0",
  "description": "Lightweight Telegram control surface for local OpenAI Codex",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --disable-warning=ExperimentalWarning dist/src/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run",
    "setup": "bash scripts/setup-env.sh",
    "config:check": "tsx src/check-config.ts",
    "service:install": "bash scripts/install-user-service.sh",
    "service:uninstall": "bash scripts/uninstall-user-service.sh",
    "service:status": "systemctl --user status cdxtg.service --no-pager"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.144.1",
    "dotenv": "^17.2.3",
    "grammy": "^1.44.0",
    "mqtt": "^5.15.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
